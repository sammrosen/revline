# RevLine Platform Environment Variables
# Copy this file to .env and fill in your values
# See docs/ENV.md for detailed documentation

# =============================================================================
# 🔴 REQUIRED - Cannot run without these
# =============================================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# 32-byte hex key for encrypting client secrets (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SRB_ENCRYPTION_KEY=

# Stripe secret key for webhook signature verification
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_

# =============================================================================
# 🟡 REQUIRED FOR PRODUCTION (optional in dev)
# =============================================================================
  # Resend API key for sending health check alert emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_

# Email address to receive health check alerts
ADMIN_ALERT_EMAIL=your@email.com

# Secret for authenticating cron job requests
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# =============================================================================
# 🟢 OPTIONAL
# =============================================================================

# Your deployed application URL (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=

# Node environment (auto-set by Railway/Vercel in production)
NODE_ENV=development



