# RevLine Platform Environment Variables
# Copy this file to .env and fill in your values
# See docs/ENV.md for detailed documentation

# =============================================================================
# 🔴 REQUIRED - Cannot run without these
# =============================================================================

# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# 32-byte hex key for encrypting client secrets (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Version 1 is current. Keep legacy SRB_ENCRYPTION_KEY if migrating from older version.
REVLINE_ENCRYPTION_KEY_V1=
# SRB_ENCRYPTION_KEY=  # Legacy key (version 0) - only needed if migrating old secrets

# Stripe secret key for webhook signature verification
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_API_KEY=sk_test_

# =============================================================================
# 🟡 REQUIRED FOR PRODUCTION (optional in dev)
# =============================================================================
  # Resend API key for sending health check alert emails
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_

# Email address to receive health check alerts
ADMIN_ALERT_EMAIL=your@email.com

# Secret for authenticating cron job requests
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# =============================================================================
# 🟢 OPTIONAL
# =============================================================================

# Your deployed application URL (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=

# Pushover notification credentials for admin mobile alerts
# Create an app at: https://pushover.net/apps/build (get API Token)
# User key is on your dashboard at: https://pushover.net/
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Node environment (auto-set by Railway/Vercel in production)
NODE_ENV=development

# Setup code to protect /admin/setup from unauthorized account creation
# If set, users must enter this code on the setup page to create an admin account
# Remove or leave empty after initial setup
SETUP_CODE=

# =============================================================================
# 🧪 TESTING (for running npm run test)
# =============================================================================

# Separate Postgres database for tests (prevents polluting production data)
TEST_DATABASE_URL=

# =============================================================================
# 📋 QUICK COPY-PASTE (fill in values)
# =============================================================================
DATABASE_URL=
REVLINE_ENCRYPTION_KEY_V1=
STRIPE_API_KEY=
RESEND_API_KEY=
ADMIN_ALERT_EMAIL=
CRON_SECRET=
NEXT_PUBLIC_APP_URL=
TEST_DATABASE_URL=
SETUP_CODE=
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=