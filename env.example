# RevOps MVP Environment Variables
# Rename this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# Your Postgres connection string
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# =============================================================================
# ENCRYPTION
# =============================================================================
# 32-byte hex key for encrypting client secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SRB_ENCRYPTION_KEY=

# =============================================================================
# MONITORING & ALERTS
# =============================================================================
# Resend API key for sending alert emails
RESEND_API_KEY=re_xxxx

# Email address to receive health check alerts
ADMIN_ALERT_EMAIL=your@email.com

# Secret for authenticating cron job requests
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# =============================================================================
# LEGACY (will be removed after migration to DB)
# =============================================================================
# These are only needed during initial migration
# After running db:seed, secrets are stored encrypted in the database

# MailerLite API key (for migration only)
MAILERLITE_API_KEY=

# Stripe API key (for constructEvent verification)
STRIPE_API_KEY=

# Legacy per-client secrets (for reference during migration)
# MAILERLITE_GROUP_ID_SAM=
# MAILERLITE_CUSTOMER_GROUP_SAM=
# STRIPE_WEBHOOK_SECRET_SAM=

