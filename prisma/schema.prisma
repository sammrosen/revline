// RevOps MVP Database Schema
// Source of truth for workspaces, integrations, leads, events, and user auth

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ORGANIZATION MANAGEMENT
// =============================================================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique // Used for org identification (e.g., "revline", "acme")
  createdAt DateTime @default(now()) @map("created_at")

  members    OrganizationMember[]
  workspaces Workspace[]
  templates  OrganizationTemplate[]

  @@map("organizations")
}

// Join table for user-organization access with permissions
model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  isOwner        Boolean  @default(false) @map("is_owner")
  permissions    Json     @default("{}") // OrgPermissions type
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// Organization-scoped templates (forms become org-scoped)
model OrganizationTemplate {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  type            String   // 'booking', 'signup', etc.
  name            String
  schema          Json     // Field definitions (copy schema)
  defaultCopy     Json     @map("default_copy")
  defaultBranding Json?    @map("default_branding")
  enabled         Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
  @@map("organization_templates")
}

// =============================================================================
// WORKSPACE MANAGEMENT
// =============================================================================

model Workspace {
  id             String          @id @default(uuid())
  organizationId String?         @map("organization_id") // Optional during migration, required by app logic
  name           String
  slug           String          @unique // Used for ?source= routing (e.g., "sam", "demo")
  status         WorkspaceStatus @default(ACTIVE)
  timezone       String          @default("America/New_York") // IANA timezone for health check business hours
  createdById    String?         @map("created_by_id") // User who created this workspace
  createdAt      DateTime        @default(now()) @map("created_at")

  // Custom domain configuration
  customDomain      String?   @unique @map("custom_domain") // e.g., "book.clientgym.com"
  domainVerifyToken String?   @map("domain_verify_token") // TXT record verification token
  domainVerified    Boolean   @default(false) @map("domain_verified")
  domainVerifiedAt  DateTime? @map("domain_verified_at")

  // Custom lead pipeline stages (JSON array of { key, label, color })
  leadStages        Json      @default("[{\"key\":\"CAPTURED\",\"label\":\"Captured\",\"color\":\"#6B7280\"},{\"key\":\"BOOKED\",\"label\":\"Booked\",\"color\":\"#3B82F6\"},{\"key\":\"PAID\",\"label\":\"Paid\",\"color\":\"#10B981\"},{\"key\":\"DEAD\",\"label\":\"Dead\",\"color\":\"#EF4444\"}]") @map("lead_stages")

  // Custom lead property schema (JSON array of { key, label, type, required })
  // Defines what custom properties leads in this workspace can have
  leadPropertySchema Json?    @map("lead_property_schema")

  // Pages configuration (forms, branding, copy, theme, etc.)
  // Replaces the old REVLINE integration meta -- pages are a built-in feature, not an integration
  pagesConfig        Json?    @map("pages_config")

  organization       Organization?          @relation(fields: [organizationId], references: [id])
  members            WorkspaceMember[]
  assignments        WorkspaceAssignment[]
  integrations       WorkspaceIntegration[]
  leads              Lead[]
  events             Event[]
  workflows          Workflow[]
  workflowExecutions WorkflowExecution[]
  webhookEvents      WebhookEvent[]
  idempotencyKeys    IdempotencyKey[]
  pendingBookings    PendingBooking[]
  agents             Agent[]
  conversations      Conversation[]
  optOutRecords      OptOutRecord[]
  followUps          FollowUp[]
  consentRecords     ConsentRecord[]
  webchatConfigs     WebchatConfig[]

  @@index([organizationId])
  @@map("workspaces")
}

// Optional per-workspace user assignment (for granular access control)
model WorkspaceAssignment {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("workspace_assignments")
}

enum WorkspaceStatus {
  ACTIVE
  PAUSED
}

// =============================================================================
// INTEGRATION SECRETS & CONFIG
// =============================================================================

model WorkspaceIntegration {
  id           String          @id @default(uuid())
  workspaceId  String          @map("workspace_id")
  integration  IntegrationType
  secrets      Json? // Array of { id: string, name: string, encryptedValue: string, keyVersion: number }
  meta         Json? // Non-sensitive config: groups, routing, product_map, etc.
  healthStatus HealthStatus    @default(GREEN) @map("health_status")
  lastSeenAt   DateTime?       @map("last_seen_at")
  createdAt    DateTime        @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, integration])
  @@map("workspace_integrations")
}

enum IntegrationType {
  MAILERLITE
  STRIPE
  CALENDLY
  MANYCHAT
  ABC_IGNITE
  REVLINE
  RESEND
  TWILIO
  ANTHROPIC
  OPENAI
  PIPEDRIVE
}

enum HealthStatus {
  GREEN
  YELLOW
  RED
}

// =============================================================================
// LEAD TRACKING (Ops state only, not a CRM)
// =============================================================================

model Lead {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  email       String
  source      String? // e.g., "landing", "ig_dm"
  stage       String    @default("CAPTURED")
  errorState  String?   @map("error_state")
  properties  Json?     // Custom lead properties (validated against workspace.leadPropertySchema)
  createdAt   DateTime  @default(now()) @map("created_at")
  lastEventAt DateTime  @default(now()) @map("last_event_at")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  events        Event[]
  conversations Conversation[]

  @@unique([workspaceId, email])
  @@index([workspaceId, stage])
  @@index([workspaceId, lastEventAt])
  @@map("leads")
}


// =============================================================================
// EVENT LEDGER (Append-only, primary debugging surface)
// =============================================================================

model Event {
  id           String      @id @default(uuid())
  workspaceId  String      @map("workspace_id")
  leadId       String?     @map("lead_id")
  system       EventSystem
  eventType    String      @map("event_type")
  success      Boolean
  errorMessage String?     @map("error_message")
  metadata     Json?       @map("metadata")
  createdAt    DateTime    @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([success, createdAt])
  @@map("events")
}

enum EventSystem {
  BACKEND
  MAILERLITE
  STRIPE
  CALENDLY
  MANYCHAT
  ABC_IGNITE
  RESEND
  TWILIO
  OPENAI
  ANTHROPIC
  PIPEDRIVE
  AGENT
  CRON
  WORKFLOW
}

// =============================================================================
// USER AUTHENTICATION & WORKSPACE MEMBERSHIP
// =============================================================================

model User {
  id             String   @id @default(uuid())
  email          String   @unique // User identity for login
  name           String? // Display name
  passwordHash   String   @map("password_hash")
  totpSecret     String?  @map("totp_secret") // Encrypted with AES-256-GCM, null if 2FA not set up
  totpKeyVersion Int      @default(0) @map("totp_key_version") // Key version used to encrypt totpSecret
  totpEnabled    Boolean  @default(false) @map("totp_enabled")
  recoveryCodes  Json?    @map("recovery_codes") // Array of {hash: string, used: boolean}
  createdAt      DateTime @default(now()) @map("created_at")

  sessions                Session[]
  memberships             WorkspaceMember[]
  organizationMemberships OrganizationMember[]
  workspaceAssignments    WorkspaceAssignment[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("sessions")
}

// Join table for user-workspace access with roles
model WorkspaceMember {
  id          String        @id @default(uuid())
  userId      String        @map("user_id")
  workspaceId String        @map("workspace_id")
  role        WorkspaceRole @default(ADMIN)
  createdAt   DateTime      @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@map("workspace_members")
}

enum WorkspaceRole {
  OWNER // Full control, can delete workspace, manage other owners
  ADMIN // Can manage integrations, workflows, view all data
  MEMBER // Can view and edit most things, no secret management
  VIEWER // Read-only access
}

// =============================================================================
// WORKFLOW ENGINE
// =============================================================================

model Workflow {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  name        String
  description String?
  enabled     Boolean @default(true)

  // Trigger configuration
  triggerAdapter   String @map("trigger_adapter") // 'calendly', 'stripe', 'revline', etc.
  triggerOperation String @map("trigger_operation") // 'booking_created', 'payment_succeeded', etc.
  triggerFilter    Json?  @map("trigger_filter") // Optional: { "payload.product": "fit1" }

  // Actions to execute (ordered array of WorkflowAction)
  actions Json // [{ adapter, operation, params }]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace  Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions WorkflowExecution[]

  @@index([workspaceId, enabled])
  @@index([workspaceId, triggerAdapter, triggerOperation])
  @@map("workflows")
}

model WorkflowExecution {
  id          String @id @default(uuid())
  workflowId  String @map("workflow_id")
  workspaceId String @map("workspace_id")

  // Correlation for tracing
  correlationId String? @map("correlation_id") @db.Uuid

  // Trigger info (denormalized for history)
  triggerAdapter   String @map("trigger_adapter")
  triggerOperation String @map("trigger_operation")
  triggerPayload   Json   @map("trigger_payload")

  // Execution result
  status        WorkflowExecutionStatus @default(RUNNING)
  actionResults Json?                   @map("action_results") // Array of { action, result }
  error         String?

  // Retry tracking
  retryCount       Int       @default(0) @map("retry_count")
  lastRetryAt      DateTime? @map("last_retry_at")
  retryRequestedBy String?   @map("retry_requested_by") // Admin ID for audit

  // Timing
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflow  Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workspaceId, startedAt])
  @@index([workflowId, startedAt])
  @@index([status])
  @@index([correlationId])
  @@map("workflow_executions")
}

enum WorkflowExecutionStatus {
  RUNNING
  COMPLETED
  COMPLETED_WITH_WARNINGS
  FAILED
}

// =============================================================================
// RELIABILITY INFRASTRUCTURE
// =============================================================================

// Webhook event deduplication and raw payload storage
model WebhookEvent {
  id                  String             @id @default(uuid())
  workspaceId         String             @map("workspace_id")
  correlationId       String             @map("correlation_id") @db.Uuid
  provider            String // 'stripe', 'calendly', 'revline'
  providerEventId     String             @map("provider_event_id") // Stripe event ID, Calendly URI, etc.
  rawBody             String             @map("raw_body") @db.Text // Exact bytes for signature verification
  rawHeaders          Json?              @map("raw_headers") // Headers needed for verification
  parsedPayload       Json?              @map("parsed_payload") // Convenience parsed form
  status              WebhookEventStatus @default(PENDING)
  error               String?
  receivedAt          DateTime           @default(now()) @map("received_at")
  processingStartedAt DateTime?          @map("processing_started_at")
  processedAt         DateTime?          @map("processed_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider, providerEventId])
  @@index([status, receivedAt])
  @@map("webhook_events")
}

enum WebhookEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

// Idempotency keys for action deduplication
model IdempotencyKey {
  id          String               @id @default(uuid())
  workspaceId String               @map("workspace_id")
  key         String // Hash of (action + params)
  status      IdempotencyKeyStatus @default(PENDING)
  result      Json?
  error       String?
  createdAt   DateTime             @default(now()) @map("created_at")
  completedAt DateTime?            @map("completed_at")
  expiresAt   DateTime?            @map("expires_at") // Auto-cleanup

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, key])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

enum IdempotencyKeyStatus {
  PENDING
  COMPLETED
  FAILED
}

// =============================================================================
// PENDING BOOKINGS (Magic Link Flow)
// =============================================================================

// Provider-agnostic pending booking for magic link confirmation
// Supports ABC Ignite, Calendly, and future booking providers
model PendingBooking {
  id            String               @id @default(uuid())
  workspaceId   String               @map("workspace_id")

  // Provider identification (enables multi-provider support)
  provider      String               // 'abc_ignite', 'calendly', etc.

  // Customer info (generic - works for any provider)
  customerId    String               @map("customer_id")    // Member ID, Calendly invitee, etc.
  customerEmail String               @map("customer_email")
  customerName  String?              @map("customer_name")

  // Booking details (generic)
  staffId       String?              @map("staff_id")       // Trainer, host, etc.
  staffName     String?              @map("staff_name")
  serviceId     String?              @map("service_id")     // Event type, service, etc.
  serviceName   String?              @map("service_name")
  scheduledAt   DateTime             @map("scheduled_at")

  // Provider-specific context data (JSON blob for flexibility)
  // e.g., { barcode, homeClub } for ABC member context
  // e.g., { inviteeUri } for Calendly
  providerData  Json?                @map("provider_data")

  // The EXACT payload to send to the provider API
  // Built at request time when all context is available
  // This is what gets POSTed - no transformation needed at confirm time
  providerPayload Json?              @map("provider_payload")

  // Magic link security (SHA-256 hash of token)
  tokenHash     String               @unique @map("token_hash")

  // Status tracking
  status        PendingBookingStatus @default(PENDING)
  expiresAt     DateTime             @map("expires_at")
  confirmedAt   DateTime?            @map("confirmed_at")
  externalId    String?              @map("external_id")    // Provider's booking ID after confirmation
  failureReason String?              @map("failure_reason")

  createdAt     DateTime             @default(now()) @map("created_at")

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([workspaceId, customerId, status])
  @@index([workspaceId, provider])
  @@index([expiresAt])
  @@map("pending_bookings")
}

enum PendingBookingStatus {
  PENDING
  CONFIRMED
  EXPIRED
  FAILED
}

// =============================================================================
// AGENT ENGINE
// =============================================================================

model Agent {
  id          String  @id @default(uuid())
  workspaceId String  @map("workspace_id")
  name        String
  description String?

  // Multi-channel config — JSON array of { channel, integration, address? }
  channels Json @default("[]")

  // Deprecated — kept for migration backcompat, no longer written by new code
  channelType        String? @map("channel_type")
  channelIntegration String? @map("channel_integration")
  channelAddress     String? @map("channel_address")

  // AI config -- which AI integration to use
  aiIntegration String @map("ai_integration") // IntegrationType value: "OPENAI" or "ANTHROPIC"

  // Prompt & behavior
  systemPrompt        String  @map("system_prompt") @db.Text
  initialMessage      String? @map("initial_message") @db.Text
  modelOverride       String? @map("model_override")
  temperatureOverride Float?  @map("temperature_override")
  maxTokensOverride   Int?    @map("max_tokens_override")

  // Limits & guardrails
  maxMessagesPerConversation Int     @default(50)   @map("max_messages_per_conversation")
  maxTokensPerConversation   Int     @default(100000) @map("max_tokens_per_conversation")
  conversationTimeoutMinutes Int     @default(1440) @map("conversation_timeout_minutes")
  responseDelaySeconds       Int     @default(0)    @map("response_delay_seconds")
  autoResumeMinutes          Int     @default(60)   @map("auto_resume_minutes")
  rateLimitPerHour           Int     @default(60)   @map("rate_limit_per_hour")
  fallbackMessage            String? @map("fallback_message")
  escalationPattern          String? @map("escalation_pattern")
  faqOverrides               Json?   @map("faq_overrides")
  allowUnicode               Boolean @default(false) @map("allow_unicode")

  // Follow-up sequence config
  followUpEnabled     Boolean @default(false) @map("follow_up_enabled")
  followUpAiGenerated Boolean @default(true) @map("follow_up_ai_generated")
  followUpSequence    Json    @default("[]") @map("follow_up_sequence")

  // Allowed event emissions (JSON array of event type strings the bot can emit)
  allowedEvents Json @default("[]") @map("allowed_events")

  // Enabled tools (JSON array of tool name strings from the tool registry)
  enabledTools Json @default("[]") @map("enabled_tools")

  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  files          AgentFile[]
  followUps      FollowUp[]
  webchatConfigs WebchatConfig[]

  @@index([workspaceId, active])
  @@map("agents")
}

model AgentFile {
  id          String   @id @default(uuid())
  agentId     String   @map("agent_id")
  filename    String
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  textContent String   @map("text_content") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_files")
}

model WebchatConfig {
  id           String  @id @default(uuid())
  workspaceId  String  @map("workspace_id")
  agentId      String  @map("agent_id")
  name         String
  brandColor   String  @default("#2563eb") @map("brand_color")
  chatName     String  @default("Chat") @map("chat_name")
  collectEmail Boolean @default(true) @map("collect_email")
  collectPhone Boolean @default(false) @map("collect_phone")
  greeting     String? @db.Text
  active       Boolean @default(true)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("webchat_configs")
}

model Conversation {
  id          String @id @default(uuid())
  workspaceId String @map("workspace_id")
  agentId     String @map("agent_id")
  leadId      String? @map("lead_id")

  // Channel context (how to reply)
  channel            String  // "SMS" | "EMAIL" | "WEB_CHAT"
  channelIntegration String? @map("channel_integration") // "TWILIO" | "RESEND" | "BUILT_IN"
  contactAddress     String  @map("contact_address") // Lead's phone/identifier
  channelAddress     String  @map("channel_address") // Bot's phone/identifier (Twilio number)

  status       ConversationStatus @default(ACTIVE)
  messageCount Int    @default(0) @map("message_count")
  totalTokens  Int    @default(0) @map("total_tokens")

  metadata Json? // Flexible: detected intents, goal progress, etc.
  isTest   Boolean @default(false) @map("is_test")

  pausedAt  DateTime? @map("paused_at")
  pausedBy  String?   @map("paused_by")

  startedAt     DateTime  @default(now()) @map("started_at")
  lastMessageAt DateTime? @map("last_message_at")
  endedAt       DateTime? @map("ended_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  agent     Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages  ConversationMessage[]
  followUps FollowUp[]

  @@index([workspaceId, status])
  @@index([agentId, status])
  @@index([contactAddress, channelAddress, status])
  @@map("conversations")
}

enum ConversationStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ESCALATED
  TIMED_OUT
}

model ConversationMessage {
  id             String @id @default(uuid())
  conversationId String @map("conversation_id")

  role    MessageRole
  content String      @db.Text

  // Token tracking
  promptTokens     Int @default(0) @map("prompt_tokens")
  completionTokens Int @default(0) @map("completion_tokens")

  turnLog Json? @map("turn_log")

  createdAt DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("conversation_messages")
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model OptOutRecord {
  id             String  @id @default(uuid())
  workspaceId    String  @map("workspace_id")
  contactAddress String  @map("contact_address")
  reason         String  // Keyword that triggered opt-out: "STOP", "UNSUBSCRIBE", etc.
  source         String  @default("agent") // "agent", "manual", "twilio_webhook"
  agentId        String? @map("agent_id")
  conversationId String? @map("conversation_id")
  createdAt      DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, contactAddress])
  @@index([workspaceId])
  @@map("opt_out_records")
}

model FollowUp {
  id             String   @id @default(uuid())
  workspaceId    String   @map("workspace_id")
  conversationId String   @map("conversation_id")
  agentId        String   @map("agent_id")
  contactAddress String   @map("contact_address")
  channelAddress String   @map("channel_address")

  stepIndex      Int      @map("step_index")
  scheduledAt    DateTime @map("scheduled_at")
  status         FollowUpStatus @default(PENDING)

  skipReason     String?  @map("skip_reason")
  sentAt         DateTime? @map("sent_at")
  messageText    String?  @map("message_text") @db.Text

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent         Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([status, scheduledAt])
  @@index([conversationId, status])
  @@index([workspaceId])
  @@map("follow_ups")
}

enum FollowUpStatus {
  PENDING
  SENT
  SKIPPED
  CANCELLED
}

model ConsentRecord {
  id               String        @id @default(uuid())
  workspaceId      String        @map("workspace_id")
  contactAddress   String        @map("contact_address")
  channel          String        // SMS, EMAIL, WHATSAPP, INSTAGRAM — string for extensibility
  consentType      ConsentType   @map("consent_type")
  method           ConsentMethod
  languagePresented String       @map("language_presented") @db.Text
  ipAddress        String?       @map("ip_address")
  grantedAt        DateTime      @default(now()) @map("granted_at")
  expiresAt        DateTime?     @map("expires_at")
  revokedAt        DateTime?     @map("revoked_at")

  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, contactAddress, channel])
  @@index([workspaceId])
  @@index([workspaceId, contactAddress])
  @@map("consent_records")
}

enum ConsentType {
  MARKETING
  TRANSACTIONAL
}

enum ConsentMethod {
  WEB_FORM
  SMS_KEYWORD
  IN_PERSON
  API
}
